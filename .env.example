# Copy this file to .env and adjust the values for your USB printer.
PRINTER_VENDOR_ID=0x0000
PRINTER_PRODUCT_ID=0x0000
PRINTER_IN_EP=0x82
PRINTER_OUT_EP=0x01
PRINTER_TIMEOUT=0
PRINTER_PROFILE=TM-T88III
PRINTER_CUT_MODE=FULL
APP_DEBUG=false
APP_CORS_ALLOWED_ORIGINS=["https://example.com"]
API_BEARER_TOKEN=replace-with-a-strong-token
